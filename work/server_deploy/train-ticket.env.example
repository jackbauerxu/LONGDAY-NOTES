TRAIN_TICKET_ALLOWED_ORIGINS=https://YOUR-PAGES-NAME.pages.dev,http://127.0.0.1:4173
TRAIN_TICKET_APP_DIR=/opt/quiet-atlas-api
TRAIN_TICKET_DATA_DIR=/opt/quiet-atlas-api/data
TRAIN_TICKET_HEADLESS=true
TRAIN_TICKET_SLOW_MO=80
TRAIN_TICKET_AVAILABILITY_TIMEOUT_MS=60000
TRAIN_TICKET_MAX_OFFERS=8
TRAIN_TICKET_RATE_KZT=0.0145
TRAIN_TICKET_RATE_UZS=0.000564
TRAIN_TICKET_ALIPAY_QR_URL=

# Availability sync rules:
# - The service opens the English railway results page for the chosen route and date.
# - Train cards, departure/arrival time, duration, seat class, remaining count, seat numbers, and local price must all come from that realtime result.
# - If realtime data is unavailable, the API returns 503 or an empty list, and the frontend cannot continue to order preview.
